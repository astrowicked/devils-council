{
  // markdownlint-cli2 config; see https://github.com/DavidAnson/markdownlint
  "default": true,

  // Line length: relaxed. Persona prompts and README have long command examples.
  "MD013": false,

  // Blanks around lists: too strict for mixed-content docs with inline code.
  "MD032": false,

  // Code block style: allow both fenced and indented.
  "MD046": false,

  // Allow inline HTML — README and SKILL.md use <details>, <img>, etc.
  "MD033": false,

  // Don't require language on every fenced code block (shell shorthand is common).
  "MD040": false,

  // Bare URLs are fine in prose documentation.
  "MD034": false,

  // Allow duplicate headings across sections (we reuse "## Action", "## Context" in plans).
  "MD024": { "siblings_only": true },

  // First line doesn't have to be H1 — frontmatter is common.
  "MD041": false,

  // Table column style is stylistic; we use compact tables throughout.
  "MD060": false,

  "globs": [
    "**/*.md"
  ],

  "ignores": [
    ".planning/**",
    "**/fixtures/**",
    "node_modules/**",
    ".claude/**",
    ".council/**",
    "agents/**",
    "skills/**",
    "commands/**",
    "CLAUDE.md",
    "CHANGELOG.md"
  ]
}
