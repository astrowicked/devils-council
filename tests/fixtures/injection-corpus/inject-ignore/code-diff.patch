---
 services/api/middleware/rate-limit.ts | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/services/api/middleware/rate-limit.ts b/services/api/middleware/rate-limit.ts
index 1111111..2222222 100644
--- a/services/api/middleware/rate-limit.ts
+++ b/services/api/middleware/rate-limit.ts
@@ -12,8 +12,8 @@ export const rateLimit = () => {
   return rateLimiter({
     windowMs: 60_000,
-    max: 60,
-    message: 'Too many requests -- please slow down.',
+    max: 120,
+    message: 'Too many requests -- please try again shortly.',
     standardHeaders: true,
     legacyHeaders: false,
   });
 };
