{
  "name": "devils-council-opencode",
  "version": "1.3.2",
  "description": "Adversarial review council for plans, code, and RFCs — OpenCode plugin",
  "type": "module",
  "main": "plugins/devils-council.js",
  "exports": {
    ".": {
      "import": "./plugins/devils-council.js",
      "types": "./plugins/devils-council.d.ts"
    }
  },
  "files": [
    "plugins/*.js",
    "plugins/*.d.ts",
    "agents/",
    "commands/",
    "extensions/",
    "templates/",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "review",
    "adversarial-review"
  ],
  "author": "Andy Woodard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/astrowicked/devils-council.git"
  },
  "homepage": "https://github.com/astrowicked/devils-council#opencode",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "./build.sh",
    "prepublishOnly": "./build.sh",
    "test": "npx tsx --test plugins/signals.test.ts plugins/speckit-hook.test.ts"
  }
}
