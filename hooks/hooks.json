{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'set -e; file=$(jq -r .tool_input.file_path); case \"$file\" in */agents/*.md) \"${CLAUDE_PLUGIN_ROOT}/scripts/validate-personas.sh\" \"$file\" ;; *) exit 0 ;; esac'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "if": "Agent(gsd-plan-checker)",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/dc-gsd-wrap.sh plan-checker"
          },
          {
            "type": "command",
            "if": "Agent(gsd-code-reviewer)",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/dc-gsd-wrap.sh code-reviewer"
          }
        ]
      }
    ]
  }
}
